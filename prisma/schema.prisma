  menuItem  MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@unique([foodOrderId, lineNo], map: "ux_food_order_items_line_active")
  @@index([foodOrderId], map: "ix_food_order_items_food_order_id")
  @@map("food_order_items")
}

model Notification {
  id                String              @id @default(uuid()) @db.Uuid
  hotelId           String              @map("hotel_id") @db.Uuid
  recipientUserId   String              @map("recipient_user_id") @db.Uuid
  notificationType  String              @map("notification_type") @db.Text
  channel           NotificationChannel @default(in_app)
  status            NotificationStatus  @default(queued)
  title             String              @db.Text
  body              String              @db.Text
  payload           Json                @default("{}")
  relatedEntityType String?             @map("related_entity_type") @db.Text
  relatedEntityId   String?             @map("related_entity_id") @db.Uuid
  scheduledAt       DateTime?           @map("scheduled_at") @db.Timestamptz(6)
  sentAt            DateTime?           @map("sent_at") @db.Timestamptz(6)
  readAt            DateTime?           @map("read_at") @db.Timestamptz(6)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?           @map("deleted_at") @db.Timestamptz(6)

  hotel         Hotel   @relation(fields: [hotelId], references: [id], onDelete: Restrict)
  recipientUser AppUser @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Restrict)

  @@index([recipientUserId, status, createdAt(sort: Desc)], map: "ix_notifications_recipient_status")
  @@index([hotelId, createdAt(sort: Desc)], map: "ix_notifications_hotel_id")
  @@map("notifications")
}

model ImportExportJob {
  id                String    @id @default(uuid()) @db.Uuid
  hotelId           String    @map("hotel_id") @db.Uuid
  initiatedByUserId String?   @map("initiated_by_user_id") @db.Uuid
  jobKind           JobKind   @map("job_kind")
  entityName        String    @map("entity_name") @db.Text
  fileName          String?   @map("file_name") @db.Text
  filePath          String?   @map("file_path") @db.Text
  fileFormat        String    @default("xlsx") @map("file_format") @db.Text
  status            JobStatus @default(queued)
  totalRows         Int       @default(0) @map("total_rows")
  processedRows     Int       @default(0) @map("processed_rows")
  failedRows        Int       @default(0) @map("failed_rows")
  errorReportPath   String?   @map("error_report_path") @db.Text
  startedAt         DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt       DateTime? @map("completed_at") @db.Timestamptz(6)
  metadata          Json      @default("{}")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz(6)

  hotel           Hotel    @relation(fields: [hotelId], references: [id], onDelete: Restrict)
  initiatedByUser AppUser? @relation("JobInitiator", fields: [initiatedByUserId], references: [id], onDelete: SetNull)

  @@index([hotelId, status, createdAt(sort: Desc)], map: "ix_import_export_jobs_hotel_status")
  @@map("import_export_jobs")
}
