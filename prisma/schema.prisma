generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  inactive
  suspended

  @@map("user_status")
}

model AppUser {
  id                      String                   @id @default(uuid()) @db.Uuid
  email                   String                   @db.Text
  phone                   String?                  @db.Text
  passwordHash            String                   @map("password_hash") @db.Text
  displayName             String                   @map("display_name") @db.Text
  status                  UserStatus               @default(active)
  emailVerifiedAt         DateTime?                @map("email_verified_at") @db.Timestamptz(6)
  phoneVerifiedAt         DateTime?                @map("phone_verified_at") @db.Timestamptz(6)
  lastLoginAt             DateTime?                @map("last_login_at") @db.Timestamptz(6)
  passwordChangedAt       DateTime?                @map("password_changed_at") @db.Timestamptz(6)
  locale                  String                   @default("en") @db.Text
  timezone                String                   @default("UTC") @db.Text
  metadata                Json                     @default("{}")
  failedLoginAttempts     Int                      @default(0) @map("failed_login_attempts")
  lockedUntil             DateTime?                @map("locked_until") @db.Timestamptz(6)
  emailVerificationSentAt DateTime?                @map("email_verification_sent_at") @db.Timestamptz(6)
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt               DateTime?                @map("deleted_at") @db.Timestamptz(6)
  assignedUserRoles       UserRole[]               @relation("AssignedByUser")
  auditLogs               AuditLog[]               @relation("AuditActor")
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  sessions                UserSession[]
  userRoles               UserRole[]               @relation("UserRoles")
  staffProfiles           StaffProfile[]
  customerProfiles        CustomerProfile[]
  roomStatusChanges       RoomStatusHistory[]      @relation("RoomStatusChangedBy")
  roomBlocksCreated       RoomBlock[]              @relation("RoomBlockCreatedBy")
  bookingsBooked          Booking[]                @relation("BookingBookedBy")
  bookingsCancelled       Booking[]                @relation("BookingCancelledBy")
  checkins                CheckinRecord[]          @relation("CheckinBy")
  checkouts               CheckoutRecord[]         @relation("CheckoutBy")
  invoicesIssued          Invoice[]                @relation("InvoiceIssuedBy")
  paymentsReceived        Payment[]                @relation("PaymentReceivedBy")
  paymentsMade            Payment[]                @relation("PaymentPayer")
  refundsProcessed        Refund[]                 @relation("RefundProcessedBy")
  housekeepingRequested   HousekeepingTask[]       @relation("HousekeepingRequestedBy")
  housekeepingAssigned    HousekeepingTask[]       @relation("HousekeepingAssignedTo")
  foodOrdersPlaced        FoodOrder[]              @relation("FoodOrderPlacedBy")
  notifications           Notification[]           @relation("NotificationRecipient")
  importExportJobs        ImportExportJob[]        @relation("JobInitiator")

  @@map("app_users")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @db.Text
  name            String           @db.Text
  description     String?          @db.Text
  isSystem        Boolean          @default(true) @map("is_system")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]
  userRoles       UserRole[]       @relation("RoleUsers")

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @db.Text
  moduleName      String           @map("module_name") @db.Text
  name            String           @db.Text
  description     String?          @db.Text
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz(6)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@map("role_permissions")
}

model UserRole {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  roleId           String    @map("role_id") @db.Uuid
  assignedAt       DateTime  @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedByUserId String?   @map("assigned_by_user_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)
  assignedByUser   AppUser?  @relation("AssignedByUser", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  role             Role      @relation("RoleUsers", fields: [roleId], references: [id], onDelete: Restrict)
  user             AppUser   @relation("UserRoles", fields: [userId], references: [id], onDelete: Restrict)

  @@map("user_roles")
}

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash") @db.Text
  deviceInfo       String?   @map("device_info") @db.Text
  ipAddress        String?   @map("ip_address") @db.Inet
  userAgent        String?   @map("user_agent") @db.Text
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)
  user             AppUser   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("user_sessions")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.Text
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  user      AppUser   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.Text
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  user      AppUser   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("email_verification_tokens")
}

model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  hotelId     String?   @map("hotel_id") @db.Uuid
  actorUserId String?   @map("actor_user_id") @db.Uuid
  action      String    @db.Text
  entityTable String    @map("entity_table") @db.Text
  entityId    String?   @map("entity_id") @db.Uuid
  requestId   String?   @map("request_id") @db.Uuid
  beforeData  Json?     @map("before_data")
  afterData   Json?     @map("after_data")
  metadata    Json      @default("{}")
  ipAddress   String?   @map("ip_address") @db.Inet
  userAgent   String?   @map("user_agent") @db.Text
  occurredAt  DateTime  @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  actorUser   AppUser?  @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  hotel       Hotel?    @relation(fields: [hotelId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

enum BookingStatus {
  draft
  quoted
  confirmed
  cancelled
  no_show
  checked_in
  checked_out
  completed

  @@map("booking_status")
}

enum RoomStatus {
  available
  reserved
  occupied
  dirty
  cleaning
  out_of_service
  maintenance

  @@map("room_status")
}

enum PaymentStatus {
  pending
  authorized
  captured
  failed
  voided
  partially_refunded
  refunded

  @@map("payment_status")
}

enum InvoiceStatus {
  draft
  issued
  partially_paid
  paid
  void
  overdue

  @@map("invoice_status")
}

enum OrderStatus {
  draft
  placed
  accepted
  preparing
  ready
  delivered
  cancelled
  refunded

  @@map("order_status")
}

enum HousekeepingStatus {
  requested
  assigned
  in_progress
  completed
  cancelled

  @@map("housekeeping_status")
}

enum HousekeepingPriority {
  low
  medium
  high
  urgent

  @@map("housekeeping_priority")
}

enum NotificationChannel {
  in_app
  email
  sms
  push

  @@map("notification_channel")
}

enum NotificationStatus {
  queued
  sent
  delivered
  read
  failed

  @@map("notification_status")
}

enum JobKind {
  import
  export

  @@map("job_kind")
}

enum JobStatus {
  queued
  processing
  completed
  failed
  cancelled

  @@map("job_status")
}

enum PaymentMethod {
  cash
  card
  upi
  bank_transfer
  wallet
  gateway
  other

  @@map("payment_method")
}

model Hotel {
  id                String    @id @default(uuid()) @db.Uuid
  hotelCode         String    @unique(map: "ux_hotels_code_active") @map("hotel_code") @db.Text
  name              String    @db.Text
  legalName         String?   @map("legal_name") @db.Text
  taxRegistrationNo String?   @map("tax_registration_no") @db.Text
  currencyCode      String    @default("USD") @map("currency_code") @db.Char(3)
  timezone          String    @default("UTC") @db.Text
  phone             String?   @db.Text
  email             String?   @db.Text
  website           String?   @db.Text
  addressLine1      String?   @map("address_line1") @db.Text
  addressLine2      String?   @map("address_line2") @db.Text
  city              String?   @db.Text
  state             String?   @db.Text
  postalCode        String?   @map("postal_code") @db.Text
  countryCode       String    @default("US") @map("country_code") @db.Char(2)
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz(6)

  staffProfiles       StaffProfile[]
  customerProfiles    CustomerProfile[]
  roomTypes           RoomType[]
  rooms               Room[]
  roomStatusHistories RoomStatusHistory[]
  roomBlocks          RoomBlock[]
  bookings            Booking[]
  bookingRooms        BookingRoom[]
  bookingGuests       BookingGuest[]
  checkinRecords      CheckinRecord[]
  checkoutRecords     CheckoutRecord[]
  invoices            Invoice[]
  invoiceItems        InvoiceItem[]
  payments            Payment[]
  paymentAllocations  PaymentAllocation[]
  refunds             Refund[]
  housekeepingTasks   HousekeepingTask[]
  foodCategories      FoodCategory[]
  menuItems           MenuItem[]
  foodOrders          FoodOrder[]
  foodOrderItems      FoodOrderItem[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  importExportJobs    ImportExportJob[]

  @@map("hotels")
}

model StaffProfile {
  id                    String    @id @default(uuid()) @db.Uuid
  hotelId               String    @map("hotel_id") @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  employeeNo            String    @unique(map: "ux_staff_profiles_employee_no_active") @map("employee_no") @db.Text
  department            String?   @db.Text
  designation           String?   @db.Text
  employmentType        String?   @map("employment_type") @db.Text
  hireDate              DateTime? @map("hire_date") @db.Date
  terminationDate       DateTime? @map("termination_date") @db.Date
  emergencyContactName  String?   @map("emergency_contact_name") @db.Text
  emergencyContactPhone String?   @map("emergency_contact_phone") @db.Text
  isActive              Boolean   @default(true) @map("is_active")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt             DateTime? @map("deleted_at") @db.Timestamptz(6)

  hotel Hotel   @relation(fields: [hotelId], references: [id], onDelete: Restrict)
  user  AppUser @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([userId, hotelId], map: "ux_staff_profiles_user_hotel_active")
  @@index([hotelId], map: "ix_staff_profiles_hotel_id")
  @@map("staff_profiles")
}

model CustomerProfile {
  id            String    @id @default(uuid()) @db.Uuid
  hotelId       String    @map("hotel_id") @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  customerNo    String    @unique(map: "ux_customer_profiles_customer_no_active") @map("customer_no") @db.Text
  firstName     String?   @map("first_name") @db.Text
  lastName      String?   @map("last_name") @db.Text
  dateOfBirth   DateTime? @map("date_of_birth") @db.Date
  gender        String?   @db.Text
  nationality   String?   @db.Text
  documentType  String?   @map("document_type") @db.Text
  documentNo    String?   @map("document_no") @db.Text
  addressLine1  String?   @map("address_line1") @db.Text
  addressLine2  String?   @map("address_line2") @db.Text
  city          String?   @db.Text
  state         String?   @db.Text
  postalCode    String?   @map("postal_code") @db.Text
  countryCode   String?   @default("US") @map("country_code") @db.Char(2)
  loyaltyPoints Int       @default(0) @map("loyalty_points")
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  hotel      Hotel       @relation(fields: [hotelId], references: [id], onDelete: Restrict)
  user       AppUser     @relation(fields: [userId], references: [id], onDelete: Restrict)
  bookings   Booking[]
  foodOrders FoodOrder[]

  @@unique([userId, hotelId], map: "ux_customer_profiles_user_hotel_active")
  @@index([hotelId], map: "ix_customer_profiles_hotel_id")
  @@map("customer_profiles")
}

model RoomAmenity {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique(map: "ux_room_amenities_code_active") @db.Text
  name        String    @db.Text
  category    String?   @db.Text
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  roomTypeAmenities RoomTypeAmenity[]

  @@map("room_amenities")
}

model RoomType {
  id            String    @id @default(uuid()) @db.Uuid
  hotelId       String    @map("hotel_id") @db.Uuid
  code          String    @db.Text
  name          String    @db.Text
  description   String?   @db.Text
  baseOccupancy Int       @default(1) @map("base_occupancy")
  maxOccupancy  Int       @default(2) @map("max_occupancy")
  bedType       String?   @map("bed_type") @db.Text
  roomSizeSqm   Decimal?  @map("room_size_sqm") @db.Decimal(8, 2)
  baseRate      Decimal   @default(0) @map("base_rate") @db.Decimal(14, 2)
  extraBedRate  Decimal   @default(0) @map("extra_bed_rate") @db.Decimal(14, 2)
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  hotel             Hotel             @relation(fields: [hotelId], references: [id], onDelete: Restrict)
  roomTypeRates     RoomTypeRate[]
  roomTypeAmenities RoomTypeAmenity[]
  rooms             Room[]
  bookingRooms      BookingRoom[]

  @@unique([hotelId, code], map: "ux_room_types_code_hotel_active")
  @@index([hotelId], map: "ix_room_types_hotel_id")
  @@map("room_types")
}

model RoomTypeRate {
  id            String    @id @default(uuid()) @db.Uuid
  roomTypeId    String    @map("room_type_id") @db.Uuid
  rateName      String    @map("rate_name") @db.Text
  validFrom     DateTime  @map("valid_from") @db.Date
  validTo       DateTime? @map("valid_to") @db.Date
  currencyCode  String    @default("USD") @map("currency_code") @db.Char(3)
  rateAmount    Decimal   @map("rate_amount") @db.Decimal(14, 2)
  minStayNights Int?      @map("min_stay_nights")
  maxStayNights Int?      @map("max_stay_nights")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Restrict)

  @@unique([roomTypeId, rateName, validFrom], map: "ux_room_type_rates_active")
  @@index([roomTypeId], map: "ix_room_type_rates_room_type_id")
  @@map("room_type_rates")
}

model RoomTypeAmenity {
  id         String    @id @default(uuid()) @db.Uuid
  roomTypeId String    @map("room_type_id") @db.Uuid
  amenityId  String    @map("amenity_id") @db.Uuid
  quantity   Int       @default(1)
  notes      String?   @db.Text
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)

  roomType RoomType    @relation(fields: [roomTypeId], references: [id], onDelete: Restrict)
  amenity  RoomAmenity @relation(fields: [amenityId], references: [id], onDelete: Restrict)

  @@unique([roomTypeId, amenityId], map: "ux_room_type_amenities_active")
  @@index([amenityId], map: "ix_room_type_amenities_amenity_id")
  @@map("room_type_amenities")
}

model Room {
  id               String     @id @default(uuid()) @db.Uuid
  hotelId          String     @map("hotel_id") @db.Uuid
  roomTypeId       String     @map("room_type_id") @db.Uuid
  roomNumber       String     @map("room_number") @db.Text
  floorNo          Int?       @map("floor_no")
  wing             String?    @db.Text
  status           RoomStatus @default(available)
  isSmokingAllowed Boolean    @default(false) @map("is_smoking_allowed")
  isAccessible     Boolean    @default(false) @map("is_accessible")
  notes            String?    @db.Text
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?  @map("deleted_at") @db.Timestamptz(6)

  hotel               Hotel               @relation(fields: [hotelId], references: [id], onDelete: Restrict)
  roomType            RoomType            @relation(fields: [roomTypeId], references: [id], onDelete: Restrict)
  roomStatusHistories RoomStatusHistory[]
  roomBlocks          RoomBlock[]
  bookingRooms        BookingRoom[]
  housekeepingTasks   HousekeepingTask[]

  @@unique([hotelId, roomNumber], map: "ux_rooms_room_number_hotel_active")
  @@index([hotelId], map: "ix_rooms_hotel_id")
  @@index([roomTypeId], map: "ix_rooms_room_type_id")
  @@index([status], map: "ix_rooms_status")
  @@map("rooms")
}

model RoomStatusHistory {
  id              String      @id @default(uuid()) @db.Uuid
  hotelId         String      @map("hotel_id") @db.Uuid
  roomId          String      @map("room_id") @db.Uuid
  oldStatus       RoomStatus? @map("old_status")
  newStatus       RoomStatus  @map("new_status")
  changedByUserId String?     @map("changed_by_user_id") @db.Uuid
  reason          String?     @db.Text
  changedAt       DateTime    @default(now()) @map("changed_at") @db.Timestamptz(6)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?   @map("deleted_at") @db.Timestamptz(6)

  hotel         Hotel    @relation(fields: [hotelId], references: [id], onDelete: Restrict)
  room          Room     @relation(fields: [roomId], references: [id], onDelete: Restrict)
  changedByUser AppUser? @relation("RoomStatusChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([roomId, changedAt(sort: Desc)], map: "ix_room_status_history_room_id")
  @@map("room_status_history")
}

model RoomBlock {
  id              String    @id @default(uuid()) @db.Uuid
  hotelId         String    @map("hotel_id") @db.Uuid
  roomId          String    @map("room_id") @db.Uuid
  blockType       String    @map("block_type") @db.Text
  startDate       DateTime  @map("start_date") @db.Date
  endDate         DateTime  @map("end_date") @db.Date
  reason          String?   @db.Text
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  hotel         Hotel    @relation(fields: [hotelId], references: [id], onDelete: Restrict)
  room          Room     @relation(fields: [roomId], references: [id], onDelete: Restrict)
  createdByUser AppUser? @relation("RoomBlockCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([roomId, startDate, endDate], map: "ix_room_blocks_room_id")
  @@map("room_blocks")
}

model Booking {
  id                 String        @id @default(uuid()) @db.Uuid
  hotelId            String        @map("hotel_id") @db.Uuid
